{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "jdw_billboarding",
  "rules": {
    "source_file": {
      "type": "SEQ",
      "members": [
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_line"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_statement"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "comment": {
      "type": "PATTERN",
      "value": "#[^\\n]*"
    },
    "_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_statement"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "_newline": {
      "type": "PATTERN",
      "value": "\\r?\\n"
    },
    "_statement": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "group_filter"
        },
        {
          "type": "SYMBOL",
          "name": "synth_header"
        },
        {
          "type": "SYMBOL",
          "name": "effect_definition"
        },
        {
          "type": "SYMBOL",
          "name": "default_statement"
        },
        {
          "type": "SYMBOL",
          "name": "command"
        },
        {
          "type": "SYMBOL",
          "name": "track"
        }
      ]
    },
    "group_filter": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": ">>>"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "group_name"
          }
        }
      ]
    },
    "synth_header": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "selected"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "@"
        },
        {
          "type": "SYMBOL",
          "name": "instrument_name"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": ":"
                },
                {
                  "type": "SYMBOL",
                  "name": "group_name"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "arg_list"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "additional_config"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "selected": {
      "type": "STRING",
      "value": "*"
    },
    "effect_definition": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "€"
        },
        {
          "type": "SYMBOL",
          "name": "effect_type"
        },
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "SYMBOL",
          "name": "effect_id"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "arg_list"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "default_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "DEFAULT"
        },
        {
          "type": "SYMBOL",
          "name": "arg_list"
        }
      ]
    },
    "command": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "command_type"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "address"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "command_arg"
          }
        }
      ]
    },
    "command_type": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "COMMAND"
        },
        {
          "type": "STRING",
          "value": "UPDATE_COMMAND"
        },
        {
          "type": "STRING",
          "value": "QUEUE_COMMAND"
        }
      ]
    },
    "address": {
      "type": "PATTERN",
      "value": "\\/[A-Za-z0-9_]+"
    },
    "command_arg": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -1,
        "content": {
          "type": "PATTERN",
          "value": "[^\\s#][^\\s#]*"
        }
      }
    },
    "track": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "track_metadata"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "shuttle_content"
        }
      ]
    },
    "track_metadata": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<"
        },
        {
          "type": "SYMBOL",
          "name": "group_override"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": ";"
                },
                {
                  "type": "SYMBOL",
                  "name": "arg_list"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ">"
        }
      ]
    },
    "group_override": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_]*"
    },
    "shuttle_content": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -2,
        "content": {
          "type": "PATTERN",
          "value": "[^\\s#<>@/€]([^\\n#]|\\\\\\r?\\n)*"
        }
      }
    },
    "arg_list": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "arg"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": ","
              },
              {
                "type": "SYMBOL",
                "name": "arg"
              }
            ]
          }
        }
      ]
    },
    "arg": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "arg_name"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "operator"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "ref"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "operator": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "+"
        },
        {
          "type": "STRING",
          "value": "-"
        },
        {
          "type": "STRING",
          "value": "*"
        },
        {
          "type": "STRING",
          "value": "="
        }
      ]
    },
    "arg_name": {
      "type": "PATTERN",
      "value": "[A-Za-z_]+"
    },
    "ref": {
      "type": "PATTERN",
      "value": "[A-Za-z_]+"
    },
    "number": {
      "type": "PATTERN",
      "value": "[0-9]+(\\.[0-9]+)?"
    },
    "additional_config": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -1,
        "content": {
          "type": "PATTERN",
          "value": "[^\\n#]+"
        }
      }
    },
    "instrument_name": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_]*"
    },
    "group_name": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_]*"
    },
    "effect_type": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_]*"
    },
    "effect_id": {
      "type": "PATTERN",
      "value": "[A-Za-z0-9_]+"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t]"
    },
    {
      "type": "PATTERN",
      "value": "\\\\\\r?\\n"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}