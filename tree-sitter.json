{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "jdw_billboarding",
      "camelcase": "JdwBillboarding",
      "title": "JDW Billboarding Tree Sitter",
      "scope": "source.jdw_billboarding",
      "file-types": ["bbd"],
      "injection-regex": "^(billboard|jdw_billboarding)$",
      "highlights": "queries/highlights.scm",
      "injections": "queries/injections.scm"
    }
  ],
  "metadata": {
    "version": "0.2.0",
    "license": "MIT",
    "description": "Tree sitter for JDW Billboarding notation",
    "authors": [
      {
        "name": "estrandv",
        "email": "emil.strandvik@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/estrandv/tree-sitter-jdw-billboarding"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
